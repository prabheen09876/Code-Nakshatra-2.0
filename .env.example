PORT=5000
MONGO_URI=mongodb://localhost:27017/accredify
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=7d
NODE_ENV=development

# Optional: AI commands (navbar AI panel). If neither is set, a simple fallback parser is used.
# GEMINI_API_KEY=...   # Free at https://aistudio.google.com/apikey
# OPENAI_API_KEY=sk-...
# DEBUG_AI=1           # Log why Gemini/OpenAI fell back to the built-in parser (e.g. blocked or invalid JSON)
