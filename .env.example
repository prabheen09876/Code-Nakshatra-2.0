PORT=5000
MONGO_URI=mongodb://localhost:27017/accredify
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=7d
NODE_ENV=development

# MAYA / Gemini — NOT read from this file in this project.
# Workers only load: client/.dev.vars (local) or Cloudflare Dashboard / wrangler secrets.
# In client/: copy .dev.vars.example → .dev.vars and set GEMINI_API_KEY=key (non-empty).
# npm run dev:all runs Vite + wrangler together.
# Prod: wrangler pages secret put GEMINI_API_KEY
# OPENAI_API_KEY=sk-...
# DEBUG_AI=1
